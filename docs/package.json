{
  "name": "docs-app-for-codemod-utils",
  "version": "1.8.2",
  "private": true,
  "description": "Docs app for codemod-utils",
  "homepage": "https://codemod-utils.netlify.app/",
  "repository": {
    "type": "git",
    "url": "git@github.com:ijlee2/codemod-utils.git"
  },
  "author": "Isaac J. Lee",
  "type": "module",
  "scripts": {
    "build": "vitepress build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \".vitepress/theme/**/*.css\" --allow-empty-input --cache",
    "lint:css:fix": "stylelint \".vitepress/theme/**/*.css\" --allow-empty-input --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "preview": "vitepress preview",
    "start": "vitepress dev",
    "test": "exit 0"
  },
  "devDependencies": {
    "@shared-configs/eslint-config-node": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "oxc-minify": "^0.138.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitepress": "^2.0.0-alpha.17"
  },
  "engines": {
    "node": "22.* || >= 24"
  }
}
